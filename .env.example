# Local: start Postgres with `docker compose up -d`, then `npx prisma db push` and `npm run db:seed`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/visaroute"
# Same as DATABASE_URL for local Docker. On Supabase, use the non-pooler URL for migrations.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/visaroute"

# OpenRouter API key for AI-powered document generation and checks
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-blah-blah"

# Resend API key for transactional email notifications
# Get your key at https://resend.com/api-keys
RESEND_API_KEY="blah"

# Email sender address (Resend requires a verified domain)
EMAIL_FROM="VisaRoute <noreply@visaroute.com>"

# Public app URL for email links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase (middleware session refresh + document storage). Use your project dashboard values.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SERVICE_KEY="your-service-role-key"
