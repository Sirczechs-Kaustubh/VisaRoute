# Oracle Ampere A1 Deployment Environment Configuration
# Copy this file to .env.production and fill in the values

# =============================================================================
# DATABASE (Supabase PostgreSQL)
# =============================================================================
DATABASE_URL="postgresql://postgres.your-project:VisaRoute%40123@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres"

# =============================================================================
# SUPABASE
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SERVICE_KEY="your-service-key"

# =============================================================================
# APP CONFIG
# =============================================================================
NODE_ENV="production"
PORT=3000
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# =============================================================================
# EMAIL (Resend)
# =============================================================================
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="VisaRoute <noreply@your-domain.com>"

# =============================================================================
# SCRAPER CREDENTIALS
# Create accounts on each provider portal and fill in credentials
# =============================================================================

# TLScontact (France, Germany, etc.)
TLSCONTACT_EMAIL="your-tlscontact-email@example.com"
TLSCONTACT_PASSWORD="your-tlscontact-password"

# VFS Global (Italy, Spain, etc.)
VFS_EMAIL="your-vfs-email@example.com"
VFS_PASSWORD="your-vfs-password"

# BLS International (Spain)
BLS_EMAIL="your-bls-email@example.com"
BLS_PASSWORD="your-bls-password"

# =============================================================================
# SCHEDULER
# Cron schedule for scraper checks
# Format: cron expression (default: every 30 minutes)
# =============================================================================
SCRAPER_CRON_SCHEDULE="*/30 * * * *"

# =============================================================================
# SECURITY
# =============================================================================
CRON_SECRET="your-random-secret-string-min-32-chars"
ADMIN_USERNAME="your-admin-username"
ADMIN_PASSWORD="your-admin-password"
ADMIN_SESSION_SECRET="your-session-secret-min-32-chars"

